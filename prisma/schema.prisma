generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String    @id @default(cuid())
  timezone String    @default("Asia/Karachi")
  sections Section[]
  sessions Session[]
}

model Section {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  sessions  Session[]
}

model Session {
  id        String    @id @default(cuid())
  sectionId String
  userId    String
  startTime DateTime
  endTime   DateTime?
  duration  Int?
  isActive  Boolean   @default(true)
  section   Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([isActive])
  @@index([startTime])
}
